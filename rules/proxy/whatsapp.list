# NAME: WhatsApp (Optimized)
# UPDATED: 2026-02-22
# PURPOSE: Messaging + Stable Calls

# --- Домены (твои основные правила) ---
DOMAIN-SUFFIX,whatsapp.com
DOMAIN-SUFFIX,whatsapp.net
DOMAIN-SUFFIX,whatsapp.biz
DOMAIN-SUFFIX,whatsapp-cdn.net
DOMAIN-KEYWORD,whatsapp

# --- Вспомогательные сервисы Meta (для работы медиа и API) ---
DOMAIN,graph.facebook.com
DOMAIN-SUFFIX,fbcdn.net
DOMAIN-SUFFIX,facebook.com
DOMAIN-SUFFIX,facebook.net

# --- Подключение актуальных IP-адресов для звонков ---
# Это заменяет ручной ввод IP и всегда держит список в актуальном состоянии
RULE-SET,https://raw.githubusercontent.com/HybridNetworks/whatsapp-cidr/main/WhatsApp/whatsapp_cidr_ipv4.list,PROXY,no-resolve
